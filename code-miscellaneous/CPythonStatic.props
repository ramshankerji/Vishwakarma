<!-- Injected into CPython's PCbuild/pythoncore.vcxproj via /p:ForceImportBeforeCppTargets by
     BuildCPython.ps1. Turns the stock python313.dll project into a self-contained static
     library: /MT runtime (matching every other Vishwakarma binary) and Py_NO_ENABLE_SHARED
     (applied through the force-included header, which survives MSBuild metadata escaping)
     so pyconfig.h does not declare MS_COREDLL / dllimport. -->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemDefinitionGroup>
    <ClCompile>
      <ForcedIncludeFiles>$(MSBuildThisFileDirectory)CPythonStaticForceInclude.h;%(ForcedIncludeFiles)</ForcedIncludeFiles>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
