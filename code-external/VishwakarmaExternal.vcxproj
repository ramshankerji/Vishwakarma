  <ItemGroup>
    <ClCompile Include="pocketpy\pocketpy.c">
      <!-- PK_ENABLE_OS=0 compiles out PocketPy's filesystem/OS module (hardening).
           PK_ENABLE_THREADS=0: scripts run single-threaded on the engineering
           thread, and it drops PocketPy's C11 <stdatomic.h> dependency (MSVC
           gates C11 atomics behind an experimental flag). -->
      <PreprocessorDefinitions>PK_ENABLE_OS=0;PK_ENABLE_THREADS=0;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(PocketPyDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- Vendored third-party amalgamation we don't modify: /sdl elevates
           PocketPy's intentional unsigned-negation bit tricks (C4146) to errors. -->
      <SDLCheck>false</SDLCheck>
      <!-- Same reason: upstream's py_i64/size_t -> int narrowing (C4244/C4267) emits
           ~200 warnings per build in code we never edit. Per-file so the wrappers we
           do own elsewhere in this project keep Level3. -->
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
    </ClCompile>
