  <!-- Vendored SVG renderer (lunasvg + its bundled plutovg) we don't modify: upstream's
       int/float and size_t narrowing emits ~70 warnings (C4244/C4267/C4018) every build.
       Updated as a group rather than per file so a version bump that adds sources stays
       quiet. Scoped to lunasvg on purpose: sqlite3.c and our own fast_float_wrapper.cpp
       keep Level3. Must stay after the ItemGroup above, since Update only reaches items
       that are already defined. -->
  <ItemGroup>
    <ClCompile Update="lunasvg\**\*.cpp;lunasvg\**\*.c">
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
    </ClCompile>
  </ItemGroup>
  <!-- Pre-build: check out all git submodules on a fresh clone so the sources this
       project (and every other) compiles are present. Runs before any dependency is
       consumed; a fast no-op once submodules are initialized. -->
  <Target Name="InitSubmodules" BeforeTargets="PrepareForBuild;BuildOpenSSL">
    <Message Importance="high" Text="Ensuring git submodules are initialized" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(VishwakarmaRoot)code-miscellaneous\InitSubmodules.ps1&quot; -RepoRoot &quot;$(VishwakarmaRoot).&quot;" />
  </Target>
  <!-- Pre-build: libpng's pnglibconf.h is a generated header (not checked in). Seed it
       from the checked-in prebuilt so a fresh clone compiles libpng without running
       libpng's own configure. Only when missing, so a customized header is left alone.
       Mirrors the "Prepare libpng config header" step in .github\workflows\nightly.yml. -->
  <Target Name="PrepareLibpngConfig" BeforeTargets="ClCompile" Condition="!Exists('$(MSBuildThisFileDirectory)libpng-code\pnglibconf.h')">
    <Message Importance="high" Text="Seeding libpng-code\pnglibconf.h from prebuilt" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)libpng-code\scripts\pnglibconf.h.prebuilt" DestinationFiles="$(MSBuildThisFileDirectory)libpng-code\pnglibconf.h" />
  </Target>
  <Target Name="BuildOpenSSL" BeforeTargets="ClCompile" Inputs="@(OpenSSLBuildInput)" Outputs="$(OpenSSLBuildDir)\libcrypto.lib;$(OpenSSLBuildDir)\libssl.lib">
    <Message Importance="high" Text="Building static OpenSSL $(Configuration)|$(Platform) libraries into $(OpenSSLBuildDir)" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(VishwakarmaRoot)code-miscellaneous\BuildOpenSSL.ps1&quot; -SourceDir &quot;$(OpenSSLSourceDir)&quot; -BuildDir &quot;$(OpenSSLBuildDir)&quot; -Configuration &quot;$(Configuration)&quot; -VcVarsAll &quot;$(VCInstallDir)Auxiliary\Build\vcvarsall.bat&quot;" />
  </Target>
  <!-- Post-build: build protoc + static protobuf-lite for the current Configuration|Platform.
       Protobuf is a CMake build separate from this static lib, so it lives under
       build\protobuf-x64-* and is skipped once present (delete that folder or run
       BuildProtobuf.ps1 -Force to rebuild). Vishwakarma and VishwakarmaExtension both
       depend on these products. -->
  <Target Name="BuildProtobuf" AfterTargets="Build" Condition="!Exists('$(ProtobufLibPath)')">
    <Message Importance="high" Text="Building static protobuf + protoc $(Configuration)|$(Platform) into $(ProtobufBuildDir)" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(VishwakarmaRoot)code-miscellaneous\BuildProtobuf.ps1&quot; -SourceDir &quot;$(ProtobufSourceDir)&quot; -BuildDir &quot;$(ProtobufBuildDir)&quot; -Configuration &quot;$(Configuration)&quot; -Platform &quot;$(Platform)&quot;" />
  </Target>
